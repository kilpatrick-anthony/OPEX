# Next.js app URL
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret for JWT signing
NEXTAUTH_SECRET=replace-with-a-secure-random-string

# Postgres connection string (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Legacy JWT secret used by custom auth routes (optional if those routes are removed)
JWT_SECRET=replace-with-a-secure-random-string

# Google Workspace OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ALLOWED_DOMAIN=oakberry.ie

# SMTP — email notifications to directors on new requests
# For Google Workspace: host=smtp.gmail.com, port=587, user=your-address@oakberry.ie
# Use an App Password (https://myaccount.google.com/apppasswords) for SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@oakberry.ie
SMTP_PASS=your-app-password
# Optional — defaults to "OAKBERRY OPEX <SMTP_USER>"
SMTP_FROM=OAKBERRY OPEX <noreply@oakberry.ie>
